#!/usr/bin/env bash
set -euo pipefail

# DELETE_AND_TURNIN
#
# - Reads EID, TOKEN, GITHUB (or USER) from .env
# - Calls /revoke-access
# - If successful, deletes everything in the current directory except:
#     - itself
#     - .env
# Ensure permissions are correct: chmod u+x ./DELETE_AND_TURNIN
# Usage:
#   ./DELETE_AND_TURNIN [--url https://utcs429.com/revoke-access]

URL="https://utcs429.com/revoke-access"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --url) URL="$2"; shift 2;;
    *) echo "Unknown arg: $1" >&2; exit 2;;
  esac
done

if [[ ! -f .env ]]; then
  echo "Missing .env in current directory" >&2
  exit 1
fi

# Load env
set -a
# shellcheck disable=SC1091
source .env
set +a

EID="${EID:-}"
TOKEN="${TOKEN:-}"
GITHUB="${GITHUB:-${USER:-}}"

if [[ -z "$EID" || -z "$TOKEN" ]]; then
  echo "Missing EID or TOKEN in .env" >&2
  exit 1
fi

echo "Revoking access..."

JSON="$(
  curl -sS "$URL" \
    -H 'content-type: application/json' \
    -d "{\"eid\":\"${EID}\",\"token\":\"${TOKEN}\"}"
)"

echo "Server response:"
echo "$JSON"

# Check for error field
if echo "$JSON" | grep -q '"error"'; then
  echo "Revoke failed. Aborting deletion." >&2
  exit 1
fi

echo "Revoke succeeded. Deleting local files..."

SELF="$(basename "$0")"

shopt -s dotglob nullglob

for item in *; do
  if [[ "$item" == "$SELF" ]]; then
    continue
  fi
  if [[ "$item" == ".env" ]]; then
    continue
  fi
  rm -rf -- "$item"
done

shopt -u dotglob nullglob

echo "All files removed (except $SELF and .env)."
